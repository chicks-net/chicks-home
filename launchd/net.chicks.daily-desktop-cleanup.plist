<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Label uniquely identifies this job -->
	<key>Label</key>
	<string>net.chicks.daily-desktop-cleanup</string>

	<!-- Program to run (compiled binary in launchd/ directory) -->
	<key>ProgramArguments</key>
	<array>
		<string>/Users/chicks/Documents/git/chicks-home/launchd/daily_desktop_cleanup</string>
	</array>

	<!-- Run daily at 2 AM -->
	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>2</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>

	<!-- Run at load (immediately when loaded) -->
	<key>RunAtLoad</key>
	<true/>

	<!-- Standard output log file -->
	<key>StandardOutPath</key>
	<string>/Users/chicks/Library/Logs/daily-desktop-cleanup.log</string>

	<!-- Standard error log file -->
	<key>StandardErrorPath</key>
	<string>/Users/chicks/Library/Logs/daily-desktop-cleanup.err</string>


	<!-- Do not keep alive (run once and exit) -->
	<key>KeepAlive</key>
	<false/>

	<!-- Low priority process -->
	<key>Nice</key>
	<integer>1</integer>
</dict>
</plist>
